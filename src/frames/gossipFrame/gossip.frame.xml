<Ui xmlns="http://www.blizzard.com/wow/ui/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
    <Script file="src\frames\gossipFrame\gossip.frame.lua" />
    <Frame name="DGossipFramePanelTemplate" virtual="true">
        <Size x="900" y="512" />
        <Anchors>
            <Anchor point="TOPLEFT" />
        </Anchors>
        <Layers>
            <Layer level="BACKGROUND">
                <Texture file="Interface\AddOns\ImmersiveDialogUI\src\assets\art\parchment\Parchment">
                    <Size x="512" y="512" />
                </Texture>
            </Layer>
        </Layers>
    </Frame>
    <Button name="DGossipTitleButtonTemplate" virtual="true" hidden="false">
        <Size x="190" y="20" />
        <Scripts>
            <OnClick>
                DGossipTitleButton_OnClick(self);
            </OnClick>
        </Scripts>
        <HighlightTexture
            file=""
            alphaMode="MASK" />
		<HighlightFont>
			<color r="1" g="0.8" b="0" a="1"/>
		</HighlightFont>
        <ButtonText>
            <Size x="275" y="0" />
            <Anchors>
                <Anchor point="LEFT">
                    <Offset>
                        <AbsDimension x="30" y="0" />
                        <!-- This move the text inside the button-->
                    </Offset>
                </Anchor>
            </Anchors>
        </ButtonText>
        <NormalFont inherits="DQuestButtonTitleGossip" justifyH="LEFT">
            <Anchors>
                <Anchor point="LEFT">
                    <Offset>
                        <AbsDimension x="20" y="0" />
                    </Offset>
                </Anchor>
            </Anchors>
        </NormalFont>
    </Button>
    <Frame name="DGossipFrame" toplevel="true" parent="UIParent" movable="true" enableMouse="true"
        hidden="true">
        <Size>
            <AbsDimension x="900" y="512" />
        </Size>
        <Anchors>
            <Anchor point="CENTER">
                <Offset>
                    <AbsDimension x="0" y="0" />
                </Offset>
            </Anchor>
        </Anchors>
        <Frames>
            <Frame name="DGossipNpcNameFrame">
                <Size>
                    <AbsDimension x="900" y="14" />
                </Size>
                <Anchors>
                    <Anchor point="BOTTOMLEFT" relativeTo="DGossipFrame" relativePoint="BOTTOMLEFT">
                        <Offset>
                            <AbsDimension x="0" y="14" />
                        </Offset>
                    </Anchor>
                </Anchors>
                <Layers>
                    <Layer level="ARTWORK">
                        <FontString name="DGossipFrameNpcNameText" inherits="DQuestTitleFont" justifyH="CENTER">
                            <Size>
                                <AbsDimension x="900" y="0"/>
                            </Size>
                            <Anchors>
                                <Anchor point="TOPLEFT">
                                    <Offset>
                                        <AbsDimension x="0" y="-305" />
                                    </Offset>
                                </Anchor>
                            </Anchors>
                        </FontString>
                    </Layer>
                    <Layer level="OVERLAY">
                        <Texture name="DGossipFramePortrait">
                            <Size>
                                <AbsDimension x="50" y="50" />
                            </Size>
                            <Anchors>
                                <Anchor point="TOPLEFT">
                                    <Offset>
                                        <AbsDimension x="3" y="16" />
                                    </Offset>
                                </Anchor>
                            </Anchors>
                        </Texture>
                    </Layer>
                </Layers>
                <Scripts>
                    <OnLoad>
                        self:SetFrameLevel(self:GetFrameLevel() + 2);
                    </OnLoad>
                </Scripts>
            </Frame>
            <Frame name="DGossipFrameGreetingPanel" inherits="DGossipFramePanelTemplate"
                hidden="false">
                <Frames>
                    <Button name="DGossipFrameGreetingGoodbyeButton" inherits="DUIPanelButtonTemplate" text="GOODBYE">
                        <Size>
                            <AbsDimension x="110" y="40" />
                        </Size>
                        <Anchors>
                            <Anchor point="TOPRIGHT" relativeTo="DGossipFrame" relativePoint="TOPRIGHT">
                                <Offset>
                                    <AbsDimension x="0" y="-60" />
                                </Offset>
                            </Anchor>
                        </Anchors>
                        <Layers>
                            <Layer level="ARTWORK">
                                <Texture name="$parentIcon" file="Interface\AddOns\ImmersiveDialogUI\src\assets\art\keys\esc">
                                    <Size>
                                        <AbsDimension x="26" y="26" />
                                    </Size>
                                    <Anchors>
                                        <Anchor point="LEFT" relativeTo="$parent" relativePoint="LEFT">
                                            <Offset>
                                                <AbsDimension x="-30" y="0.7" />
                                            </Offset>
                                        </Anchor>
                                    </Anchors>
                                </Texture>
                            </Layer>
                        </Layers>
                        <Scripts>
						<OnEnter>
							DGossipFrameGreetingGoodbyeButtonText:SetTextColor(1, 0.8, 0)
						</OnEnter>
						<OnLeave>
							DGossipFrameGreetingGoodbyeButtonText:SetTextColor(1, 1, 1)
						</OnLeave>
						<OnClick>
							DGossipFrame_CloseUI(self);
						</OnClick>
                        </Scripts>
                    </Button>
                    <ScrollFrame name="DGossipGreetingScrollFrame"
                        inherits="DUIPanelScrollFrameTemplate">
                        <Size>
                            <AbsDimension x="1000" y="334" />
                        </Size>
                        <Anchors>
                            <Anchor point="TOPLEFT" relativeTo="DGossipFrame">
                                <Offset>
                                    <!-- move contents of the frame -->
                                    <AbsDimension x="40" y="-90" />
                                </Offset>
                            </Anchor>
                        </Anchors>
                        <ScrollChild>
                            <Frame name="DGossipGreetingScrollChildFrame">
                                <Size>
                                    <AbsDimension x="912" y="334" />
                                </Size>
                                <Layers>
                                    <Layer>
                                        <FontString name="DGossipGreetingText" inherits="DQuestFont"
                                            text="Filler Text" justifyH="CENTER">
                                            <Size>
                                                <AbsDimension x="900" y="0" />
                                            </Size>
                                            <Anchors>
                                                <Anchor point="CENTER" relativeTo="DGossipFrameNpcNameText"
                                                    relativePoint="CENTER">
                                                    <Offset>
                                                        <AbsDimension x="0" y="-35" />
                                                    </Offset>
                                                </Anchor>
                                            </Anchors>
                                        </FontString>
                                    </Layer>
                                </Layers>
                                <Frames>
                                    <Button name="DGossipTitleButton1" inherits="DGossipTitleButtonTemplate" id="1" parent="DGossipFrame" />
                                    <Button name="DGossipTitleButton2" inherits="DGossipTitleButtonTemplate" id="2" parent="DGossipFrame" />
                                    <Button name="DGossipTitleButton3" inherits="DGossipTitleButtonTemplate" id="3" parent="DGossipFrame" />
                                    <Button name="DGossipTitleButton4" inherits="DGossipTitleButtonTemplate" id="4" parent="DGossipFrame" />
                                    <Button name="DGossipTitleButton5" inherits="DGossipTitleButtonTemplate" id="5" parent="DGossipFrame" />
                                    <Button name="DGossipTitleButton6" inherits="DGossipTitleButtonTemplate" id="6" parent="DGossipFrame" />
                                    <Button name="DGossipTitleButton7" inherits="DGossipTitleButtonTemplate" id="7" parent="DGossipFrame" />
                                    <Button name="DGossipTitleButton8" inherits="DGossipTitleButtonTemplate" id="8" parent="DGossipFrame" />
                                    <Button name="DGossipTitleButton9" inherits="DGossipTitleButtonTemplate" id="9" parent="DGossipFrame" />
                                    <Button name="DGossipTitleButton10" inherits="DGossipTitleButtonTemplate" id="10" parent="DGossipFrame" />
                                    <Button name="DGossipTitleButton11" inherits="DGossipTitleButtonTemplate" id="11" parent="DGossipFrame" />
                                    <Button name="DGossipTitleButton12" inherits="DGossipTitleButtonTemplate" id="12" parent="DGossipFrame" />
                                    <Button name="DGossipTitleButton13" inherits="DGossipTitleButtonTemplate" id="13" parent="DGossipFrame" />
                                    <Button name="DGossipTitleButton14" inherits="DGossipTitleButtonTemplate" id="14" parent="DGossipFrame" />
                                    <Button name="DGossipTitleButton15" inherits="DGossipTitleButtonTemplate" id="15" parent="DGossipFrame" />
                                    <Button name="DGossipTitleButton16" inherits="DGossipTitleButtonTemplate" id="16" parent="DGossipFrame" />
                                    <Button name="DGossipTitleButton17" inherits="DGossipTitleButtonTemplate" id="17" parent="DGossipFrame" />
                                    <Button name="DGossipTitleButton18" inherits="DGossipTitleButtonTemplate" id="18" parent="DGossipFrame" />
                                    <Button name="DGossipTitleButton19" inherits="DGossipTitleButtonTemplate" id="19" parent="DGossipFrame" />
                                    <Button name="DGossipTitleButton20" inherits="DGossipTitleButtonTemplate" id="20" parent="DGossipFrame" />
                                    <Button name="DGossipTitleButton21" inherits="DGossipTitleButtonTemplate" id="21" parent="DGossipFrame" />
                                    <Button name="DGossipTitleButton22" inherits="DGossipTitleButtonTemplate" id="22" parent="DGossipFrame" />
                                    <Button name="DGossipTitleButton23" inherits="DGossipTitleButtonTemplate" id="23" parent="DGossipFrame" />
                                    <Button name="DGossipTitleButton24" inherits="DGossipTitleButtonTemplate" id="24" parent="DGossipFrame" />
                                    <Button name="DGossipTitleButton25" inherits="DGossipTitleButtonTemplate" id="25" parent="DGossipFrame" />
                                    <Button name="DGossipTitleButton26" inherits="DGossipTitleButtonTemplate" id="26" parent="DGossipFrame" />
                                    <Button name="DGossipTitleButton27" inherits="DGossipTitleButtonTemplate" id="27" parent="DGossipFrame" />
                                    <Button name="DGossipTitleButton28" inherits="DGossipTitleButtonTemplate" id="28" parent="DGossipFrame" />
                                    <Button name="DGossipTitleButton29" inherits="DGossipTitleButtonTemplate" id="29" parent="DGossipFrame" />
                                    <Button name="DGossipTitleButton30" inherits="DGossipTitleButtonTemplate" id="30" parent="DGossipFrame" />
                                    <Button name="DGossipTitleButton31" inherits="DGossipTitleButtonTemplate" id="31" parent="DGossipFrame" />
                                    <Button name="DGossipTitleButton32" inherits="DGossipTitleButtonTemplate" id="32" parent="DGossipFrame" />
                                    <Frame name="DGossipSpacerFrame">
                                        <Size>
                                            <AbsDimension x="5" y="35" />
                                        </Size>
                                        <Anchors>
                                            <Anchor point="TOP">
                                                <Offset>
                                                    <AbsDimension x="-29" y="0" />
                                                </Offset>
                                            </Anchor>
                                        </Anchors>
                                    </Frame>
                                </Frames>
                            </Frame>
                        </ScrollChild>
                    </ScrollFrame>
                </Frames>
            </Frame>
        </Frames>
        <Scripts>
            <OnLoad>
                DGossipFrame_OnLoad(self);
            </OnLoad>
            <OnShow>
                PlaySound("igQuestListOpen");
                if ( StaticPopup_Visible("XP_LOSS") ) then
                StaticPopup_Hide("XP_LOSS");
                end
            </OnShow>
            <OnEvent>
                DGossipFrame_OnEvent(self, event, ...);
            </OnEvent>
            <OnHide>
                PlaySound("igQuestListClose");
                CloseGossip();
            </OnHide>
            <OnMouseWheel>
                return;
            </OnMouseWheel>
        </Scripts>
    </Frame>
</Ui>