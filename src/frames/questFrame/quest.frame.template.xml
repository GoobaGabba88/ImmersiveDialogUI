<Ui xmlns="http://www.blizzard.com/wow/ui/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.blizzard.com/wow/ui/">
    <Frame name="DQuestFramePanelTemplate" virtual="true">
        <Size>
            <AbsDimension x="512" y="512" />
        </Size>
        <Anchors>
            <Anchor point="TOPLEFT" />
        </Anchors>
        <Layers>
            <Layer level="BACKGROUND">
                <Texture file="Interface\AddOns\ImmersiveDialogUI\src\assets\art\parchment\Parchment">
                    <Size x="512" y="512" />
                </Texture>
            </Layer>
        </Layers>
    </Frame>
    <!-- TODO properly change the DQuestItemTemplate and  DQuestRewardItemTemplate -->
    <Button name="DQuestItemTemplate" virtual="true">
        <Size>
            <AbsDimension x="147" y="41" />
        </Size>
        <Layers>
            <Layer level="BACKGROUND">
                <Texture name="$parentBackground" file="Interface\AddOns\ImmersiveDialogUI\src\assets\art\parchment\RewardChoice-Pending">
                    <Size>
                        <AbsDimension x="190" y="50" />
                    </Size>
                    <Anchors>
                        <Anchor point="TOPLEFT">
                            <Offset>
                                <AbsDimension x="-2" y="5" />
                            </Offset>
                        </Anchor>
                    </Anchors>
                </Texture>
                <Texture name="$parentNameFrame" file="">
                    <Size>
                        <AbsDimension x="128" y="64" />
                    </Size>
                    <Anchors>
                        <Anchor point="LEFT" relativeTo="$parentIconTexture" relativePoint="RIGHT">
                            <Offset>
                                <AbsDimension x="-10" y="0" />
                            </Offset>
                        </Anchor>
                    </Anchors>
                </Texture>
            </Layer>
            <Layer level="BORDER">
                <Texture name="$parentIconTexture">
                    <Size>
                        <AbsDimension x="35" y="35" />
                    </Size>
                    <Anchors>
                        <Anchor point="TOPLEFT">
                            <Offset>
                                <AbsDimension x="5" y="-2" />
                            </Offset>
                        </Anchor>
                    </Anchors>
                </Texture>
            </Layer>
            <Layer level="ARTWORK">
                <FontString name="$parentName" inherits="DGameFontHighlight" justifyH="LEFT">
                    <Size>
                        <AbsDimension x="120" y="36" />
                    </Size>
                    <Anchors>
                        <Anchor point="LEFT" relativeTo="$parentBackground">
                            <Offset>
                                <AbsDimension x="45" y="0" />
                            </Offset>
                        </Anchor>
                    </Anchors>
                </FontString>
            </Layer>
            <Layer level="ARTWORK">
                <FontString name="$parentCount" inherits="NumberFontNormal" justifyH="RIGHT">
                    <Anchors>
                        <Anchor point="BOTTOMRIGHT" relativeTo="$parentIconTexture">
                            <Offset>
                                <AbsDimension x="-4" y="1" />
                            </Offset>
                        </Anchor>
                    </Anchors>
                </FontString>
            </Layer>
        </Layers>
        <Scripts>
            <OnLoad>
                self.hasItem = 1;
            </OnLoad>
            <OnEnter>
                if ( self:GetAlpha() > 0 ) then
                GameTooltip:SetOwner(self, "ANCHOR_RIGHT");
                if ( self.rewardType == "item" ) then
                GameTooltip:SetQuestItem(self.type, self:GetID());
                elseif ( self.rewardType == "spell" ) then
                GameTooltip:SetQuestRewardSpell();
                end
                end
                CursorUpdate();
            </OnEnter>
            <OnLeave>
                GameTooltip:Hide();
                ResetCursor();
            </OnLeave>
            <OnUpdate>
                CursorOnUpdate(self);
            </OnUpdate>
            <OnClick>
                DQuestItem_OnClick(self);
            </OnClick>
        </Scripts>
    </Button>
    <Button name="DQuestRewardItemTemplate" inherits="DQuestItemTemplate" virtual="true">
        <Scripts>
            <OnClick>
                DQuestRewardItem_OnClick(self);
            </OnClick>
        </Scripts>
    </Button>
    <Button name="DQuestTitleButtonTemplate" virtual="true">
        <Size>
            <AbsDimension x="400" y="20" />
        </Size>
        <Scripts>
            <OnClick>
            DQuestTitleButton_OnClick(self);
        </OnClick>
        </Scripts>
        <ButtonText>
            <Size>
                <AbsDimension x="275" y="0" />
            </Size>
            <Anchors>
                <Anchor point="TOPLEFT">
                    <Offset>
                        <!-- controls the text inside of greeting panel  -->
                        <AbsDimension x="0" y="0" />
                    </Offset>
                </Anchor>
            </Anchors>
        </ButtonText>
        <NormalFont  inherits="DQuestFont" justifyH="LEFT">
			<Color r="1" g="1" b="1"/>
            <Anchors>
                <Anchor point="LEFT">
                    <Offset>
                        <AbsDimension x="0" y="0" />
                    </Offset>
                </Anchor>
            </Anchors>
        </NormalFont>
    </Button>
</Ui>